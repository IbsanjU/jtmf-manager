# JTMF Manager — Environment Variables
# Copy this file to .env and fill in your values
# (Install the 'dotenv' package or set these in your shell before running npm start)

# ── Required ──────────────────────────────────────────────────────────────────
# Your Jira / Bitbucket Data Center base URL (no trailing slash)
# Used for authentication (/rest/api/2/myself) and all Xray DC REST calls
JIRA_BASE_URL=https://jira.yourcompany.com

# ── Optional ──────────────────────────────────────────────────────────────────
# Port to run the server on (default: 3000)
PORT=3000
